# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Hotkey Configuration (macOS: use cmd, Windows: use ctrl)
HOTKEY_CAPTURE=<cmd>+<shift>+s
HOTKEY_TOGGLE=<cmd>+<shift>+h

# OCR Configuration
OCR_LANGUAGES=tur+eng

# Overlay Configuration
OVERLAY_OPACITY=0.85
OVERLAY_FONT_SIZE=18

# Logging
LOG_LEVEL=INFO
